# Server (NestJS) environment template
# Copy to .env.local and fill in the secrets.

# Connection string for Prisma. The compose file defaults to family_inventory/family_inventory.
DATABASE_URL="mysql://family_inventory:family_inventory@localhost:3306/family_inventory"

# Redis is wired up for caching aggregations. When unset, the server falls back
# to an in-memory cache so dev still works without docker.
REDIS_URL="redis://localhost:6379"

# HTTP port the Nest app should listen on.
PORT=4001

# Set to "false" to skip mounting Swagger UI at /api-docs (e.g. in production).
SWAGGER_ENABLED=true

# JWT settings. Change the secret to something unique per environment.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# When set to "false", every request is allowed through and FamilyContextService
# falls back to the first non-archived family. Default behaviour for local dev so
# the legacy scaffold + the client can keep working without logging in.
AUTH_REQUIRED=false
